{
    "name": "RAG Docker Dev",
    "dockerComposeFile": [
        "../docker-compose.yaml"
    ],
    "service": "python",
    "runServices": [
        "python"
    ],
    "shutdownAction": "none",
    "workspaceFolder": "/workspace/",
    "forwardPorts": [
        8501,
        8080
    ],
    "customizations": {
        "vscode": {
            "settings": {
                "python.defaultInterpreterPath": "/opt/python-3.11-dev/bin/python3",
                "python.venvPath": "/opt"
            },
            "extensions": [
                // Container
                "ms-azuretools.vscode-docker",
                "ms-vscode-remote.remote-containers",
                //Python
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff",
                // HTML
                "ms-vscode.live-server",
                // Documents/Settings
                "yzhang.markdown-all-in-one",
                "quarto.quarto",
                "redhat.vscode-yaml",
                "ms-toolsai.jupyter",
                "streetsidesoftware.code-spell-checker",
                "tamasfe.even-better-toml",
                "aaron-bond.better-comments",
                "mermaidchart.vscode-mermaid-chart",
                "tomoki1207.pdf",
                //Code
                "oderwat.indent-rainbow",
                // Data
                "mechatroner.rainbow-csv",
                "ms-toolsai.datawrangler",
                // Git
                "mhutchie.git-graph",
                // Code
                "continue.continue"
            ]
        }
    },
    // Optional, local zsh history (requires: touch ~/.zsh_history_dev):
    "mounts": [
        "source=${localEnv:HOME}/.zsh_history_dev,target=/root/.zsh_history,type=bind,consistency=cache"
    ],
    "remoteEnv": {
        "OPENAI_API_KEY": "${localEnv:OPENAI_API_KEY:key_is_missing}",
        "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY:key_is_missing}",
        "GEMINI_API_KEY": "${localEnv:GEMINI_API_KEY:key_is_missing}",
        "LANGSMITH_API_KEY": "${localEnv:LANGSMITH_API_KEY:key_is_missing}",
        "CHROMA_DATA_PATH": "${localEnv:CHROMA_DATA_PATH:./chroma_data}",
        "RAG_API_KEYS": "${localEnv:RAG_API_KEYS:key_is_missing}"
    }
}
